# Database (matches docker-compose.yml defaults)
DB_URL=jdbc:postgresql://localhost:5432/reflectly
DB_USERNAME=test_user
DB_PASSWORD=test_password

# Backend JWT signing key (minimum 32 characters)
JWT_SECRET=change-me-to-a-secure-secret-at-least-32-chars

# Google OAuth (Web application client — same ID used by frontend)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: comma-separated allowed frontend origins for CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Optional: use prod profile locally only when testing production settings
# SPRING_PROFILES_ACTIVE=local
